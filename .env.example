# Tournament registration — Supabase keys.
# Copy this file to .env.local and fill in real values:
#     cp .env.example .env.local
# Then run:  node scripts/gen-env.mjs   (regenerates env.js)
#
# .env.local and env.js are gitignored — keys never get committed.
# The anon key is the PUBLIC key (safe to ship to the browser); never put
# the service_role / secret key here.
# See SETUP-TOURNAMENT.md for where to find these in Supabase.

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
